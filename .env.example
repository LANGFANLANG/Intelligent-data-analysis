# ── DeepSeek API 配置 ──
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── PostgreSQL 内部数据库配置 ──
DATABASE_URL=postgresql://data_agent:data_agent_pass@localhost:5432/data_agent

# ── MySQL 外部数据库直连配置 ──
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=your_readonly_user
DB_PASSWORD=your_password
DB_CHARSET=utf8mb4

# ── Agent 运行参数 ──
AGENT_MAX_STEPS=40
AGENT_TIMEOUT_SECONDS=120

# ── SQL 执行限制 ──
SQL_MAX_ROWS=1000
SQL_TIMEOUT_SEC=30
SCHEMA_CACHE_TTL_MINUTES=30

# ── 可视化参数 ──
VIZ_MAX_PIE_CATEGORIES=8
VIZ_MAX_BAR_CATEGORIES=30
VIZ_DPI=200

# ── 数据加载参数 ──
MAX_FILE_SIZE_MB=100
SAMPLE_MAX_ROWS=50000

# ── Streamlit 端口 ──
STREAMLIT_PORT=8501

# ── Langfuse 观测平台配置 ──
# 在 Langfuse UI (http://localhost:3000) 中生成 API Keys
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_HOST=http://localhost:3000

# Langfuse 服务端安全密钥（仅 Docker 自托管，用于加密 / 认证）
# 生成方式: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=changeme-generate-with-openssl
LANGFUSE_SALT=changeme-generate-with-openssl
LANGFUSE_ENCRYPTION_KEY=changeme-generate-with-openssl

# ── 限流与日志 ──
LLM_RATE_LIMIT=30
LLM_BURST_SIZE=5
LOG_LEVEL=INFO
MAX_PROMPT_LENGTH=2000
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600
